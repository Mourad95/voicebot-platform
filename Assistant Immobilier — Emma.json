                    },
                    "dejaEstime": {
                      "type": "string",
                      "description": "pour vendeur: oui/non deja fait estimer ailleurs"
                    },
                    "creneauRappel": {
                      "type": "string",
                      "description": "moment souhaite pour le rappel"
                    }
                  }
                }
              }
            }
          }
        }
      },
