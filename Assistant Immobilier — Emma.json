      {
        "execution_message_type": "static_text",
        "method": "POST",
        "description": "Envoie un SMS au conseiller avec la fiche prospect qualifiee. Appeler apres save_prospect.",
        "type": "custom",
        "url": "{{webhook_url}}/webhook/retell",
