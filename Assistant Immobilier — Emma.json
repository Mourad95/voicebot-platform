          "y": 300
        },
        "edges": [
          {
            "id": "e-notify-done",
            "destination_node_id": "node-decision-transfert",
            "transition_condition": {
              "type": "prompt",
              "prompt": "Notification traitee"
            }
          }
        ]
      },
      {
        "id": "node-decision-transfert",
        "name": "Decision transfert",
        "type": "branch",
        "instruction": {
          "type": "prompt",
          "text": "Decide si on transfere en direct ou si on prend conge avec promesse de rappel."
        },
        "else_edge": {
          "destination_node_id": "node-end-rappel",
          "id": "e-dec-else",
          "transition_condition": {
            "type": "prompt",
            "prompt": "Else"
          }
        },
        "display_position": {
          "x": 1700,
          "y": 300
        },
        "edges": [
          {
            "id": "e-dec-transfer",
            "destination_node_id": "node-ask-transfer",
            "transition_condition": {
              "type": "prompt",
              "prompt": "leadScore=hot ET on est DANS les horaires d'ouverture (comparer {{current_hour}} et {{current_day}} avec {{horaires_agence}})"
            }
          }
        ]
      },
      {
        "id": "node-ask-transfer",
        "name": "Proposer transfert",
        "type": "conversation",
        "instruction": {
          "type": "prompt",
          "text": "\"Un conseiller est disponible. Souhaitez-vous que je vous le passe maintenant, ou preferez-vous qu'il vous rappelle ?\" Ne transfere QUE si le prospect accepte explicitement."
        },
        "display_position": {
          "x": 2000,
          "y": 150
        },
        "edges": [
          {
            "id": "e-at-yes",
            "destination_node_id": "node-transfer",
            "transition_condition": {
              "type": "prompt",
              "prompt": "Le prospect accepte le transfert"
            }
          },
          {
            "id": "e-at-no",
            "destination_node_id": "node-end-rappel",
            "transition_condition": {
              "type": "prompt",
              "prompt": "Le prospect prefere etre rappele"
            }
          }
        ]
      },
      {
        "id": "node-transfer",
        "name": "Transfert",
        "type": "transfer_call",
        "transfer_destination": {
