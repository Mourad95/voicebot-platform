                    "leadType": {
                      "type": "string",
                      "description": "vente, achat, location, estimation ou autre"
                    },
                    "leadScore": {
                      "type": "string",
                      "description": "hot, warm ou cold"
                    },
                    "isVendeur": {
                      "type": "string",
                      "description": "oui si vente ou estimation, non sinon"
                    },
                    "typeBien": {
                      "type": "string",
                      "description": "appartement, maison, terrain, local, autre"
                    },
                    "secteur": {
                      "type": "string",
                      "description": "secteur geographique"
                    },
                    "budgetOuPrix": {
                      "type": "string",
                      "description": "budget pour achat/location, prix espere pour vente"
                    },
                    "surface": {
                      "type": "string",
                      "description": "surface du bien si vendeur"
                    },
                    "delai": {
                      "type": "string",
                      "description": "urgent, moins_3_mois, 3_6_mois, plus_6_mois"
                    },
                    "motivation": {
                      "type": "string",
                      "description": "raison du projet"
                    },
                    "annonceRef": {
                      "type": "string",
