        "type": "end",
        "speak_during_execution": true,
        "instruction": {
          "type": "prompt",
          "text": "\"Je suis desolee, je rencontre un probleme technique. Pouvez-vous rappeler l'agence au {{numero_agence}} ? Toutes nos excuses pour la gene occasionnee.\""
        },
        "display_position": {
          "x": 1400,
          "y": 550
        }
      }
    ],
    "start_node_id": "node-welcome",
    "start_speaker": "agent",
    "tools": [
      {
        "execution_message_type": "static_text",
        "method": "POST",
        "description": "Enregistre le prospect qualifie avec toutes ses donnees. Appeler une fois la qualification terminee.",
        "type": "custom",
        "url": "{{webhook_url}}/webhook/retell",
        "tool_id": "tool_save_prospect",
        "args_at_root": true,
        "execution_message_description": "J'enregistre votre demande.",
        "timeout_ms": 30000,
        "speak_after_execution": true,
        "name": "save_prospect",
        "response_variables": {
          "success": "$.result.success",
          "prospect_id": "$.result.prospectId"
        },
        "speak_during_execution": true,
        "parameters": {
          "type": "object",
